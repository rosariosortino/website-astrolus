---
import Layout from '../layouts/Layout.astro';
import languages from '../languages.json';
const t = languages.it;
---
<Layout lang="it" t={t}>
  <main class="max-w-4xl mx-auto px-6 py-32 text-gray-300 min-h-screen">
    <h1 class="text-4xl font-black text-white mb-8 border-b border-white/10 pb-4 uppercase tracking-tight">
      {t.legal.refund_title}
    </h1>
    <div class="prose prose-invert prose-red max-w-none space-y-4" set:html={t.legal.refund_content} />
  </main>
</Layout>
