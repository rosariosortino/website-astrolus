---
import Container from "./Container.astro"
---
<div class="relative bg-[#050505] overflow-hidden" id="home">
    <!-- SFONDO HI-TECH NEON -->
    <div class="absolute inset-0 grid grid-cols-2 -space-x-52 opacity-30 pointer-events-none">
        <div class="blur-[120px] h-80 bg-gradient-to-br from-blue-900 to-transparent"></div>
        <div class="blur-[120px] h-60 bg-gradient-to-r from-[#FF2D55] to-transparent opacity-10"></div>
    </div>

    <Container>
        <div class="relative pt-48 pb-20 ml-auto">
            <div class="lg:w-full text-center mx-auto">
                
                <!-- LOGO CENTRALE MONUMENTALE (PROTAGONISTA) -->
                <div class="relative inline-block mb-12 group">
                    <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-[#00E5FF] to-[#FF2D55] blur-[100px] opacity-20 animate-pulse group-hover:opacity-40 transition-opacity duration-700"></div>
                    <img 
                        src="/logo-platinum.png" 
                        alt="Logo Platinum Project" 
                        class="relative z-10 mx-auto transition-all duration-1000 group-hover:scale-105" 
                        style="width: 480px; max-width: 85vw; height: auto; filter: drop-shadow(0 0 60px rgba(0,229,255,0.4));"
                    />
                </div>

                <div class="max-w-4xl mx-auto">
                    <!-- TITOLO 1: ETICHETTA TECNICA -->
                    <h2 class="text-[#FF2D55] font-black text-xl md:text-2xl uppercase tracking-[0.4em] mb-6 italic">
                        FERMA TUTTO!!
                    </h2>
                    
                    <!-- TITOLO 2: BILANCIATO (Ridotto per non schiacciare il logo) -->
                    <h1 class="text-white font-black text-4xl md:text-6xl uppercase italic tracking-tighter leading-[0.9] mb-8">
                        IL KARAOKE CHE CONOSCI <br/>
                        <span class="text-[#00E5FF]">LO ABBIAMO REINVENTATO.</span>
                    </h1>
                    
                    <!-- CITAZIONE: ELEGANTE -->
                    <p class="text-gray-400 text-lg md:text-xl font-light leading-relaxed mb-12 italic opacity-80">
                        "Basta foglietti illeggibili, basi di scarsa qualità e tempi morti. <br class="hidden md:block"/> 
                        È ora di cambiare galassia."
                    </p>

                    <!-- BOX RIVOLUZIONE: STILE MODULO CONSOLE -->
                    <div class="inline-block border border-[#FFD700]/30 p-8 bg-[#FFD700]/5 rounded-3xl mb-16 max-w-3xl">
                        <h3 class="text-2xl md:text-3xl font-black text-white uppercase italic tracking-tighter mb-4">
                            FINE DELLA SCHIAVITÙ. <br/>
                            <span class="text-[#00E5FF]">BENVENUTO NELLO STANDARD LIBERO.</span>
                        </h3>
                        <p class="text-gray-400 text-base md:text-lg leading-relaxed">
                            Basta abbonamenti infiniti. Platinum Karaoke Pro crea basi professionali con <span class="text-white font-bold underline decoration-[#FFD700]">Standard Libero</span>: le crei una volta, le usi ovunque.
                        </p>
                    </div>
                </div>

                <!-- PULSANTI AZIONE -->
                <div class="flex flex-wrap justify-center gap-y-6 gap-x-8 mb-12">
                    <a href="#" class="btn-platinum-green"><span>SCARICA SETUP PLAYER</span></a>
                    <a href="#" class="btn-platinum-cyan"><span>INSTALLA MOTORE IA</span></a>
                </div>

                <!-- FORMATI SUPPORTATI (PICCOLI E DISCRETI) -->
                <div class="mb-24">
                    <p class="text-gray-600 text-[10px] md:text-xs uppercase tracking-[0.5em] font-bold">
                        SUPPORTA: MP4 • AVI • MKV • MP3+G • CDG • KFN • MP3+TESTO • ZIP
                    </p>
                </div>

                <!-- SHOWCASE PLAYER (L'ANTEPRIMA DEL SOFTWARE) -->
                <div class="relative group max-w-5xl mx-auto rounded-2xl border border-white/10 overflow-hidden shadow-2xl bg-[#0d0d0d]" id="showcase">
                    <div class="bg-[#1a1a1a] px-4 py-2 border-b border-white/5 flex items-center space-x-2">
                        <div class="w-2 h-2 rounded-full bg-[#FF1744]"></div>
                        <div class="w-2 h-2 rounded-full bg-[#FFD700]"></div>
                        <div class="w-2 h-2 rounded-full bg-[#00E676]"></div>
                        <span class="text-[9px] text-gray-500 uppercase font-black tracking-widest pl-4 italic">Platinum Core Engine v16.0 - Command Center</span>
                    </div>
                    <img src="/player-full.png" alt="Console" class="w-full h-auto opacity-95 group-hover:opacity-100 transition-all duration-500"/>
                </div>
            </div>
        </div>
    </Container>
</div>

<style>
    /* STILE PULSANTI CONSOLE */
    .btn-platinum-green { 
        @apply relative flex h-14 w-full items-center justify-center px-10 transition-all duration-300 sm:w-max border-2 border-[#00E676] bg-[#00E676] text-black font-black uppercase tracking-widest text-base hover:shadow-[0_0_50px_rgba(0,230,118,0.6)] hover:scale-110 active:scale-95; 
    }
    .btn-platinum-cyan { 
        @apply relative flex h-14 w-full items-center justify-center px-10 transition-all duration-300 sm:w-max border-2 border-[#00E5FF] text-[#00E5FF] font-black uppercase tracking-widest text-base hover:bg-[#00E5FF]/10 hover:shadow-[0_0_40px_rgba(0,229,255,0.4)] hover:scale-110 active:scale-95; 
    }
</style>
