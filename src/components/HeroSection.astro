---
import Container from "./Container.astro"
---
<div class="relative bg-[#050505] overflow-hidden" id="home">
    <!-- SFONDO AMBIENTALE -->
    <div class="absolute inset-0 grid grid-cols-2 -space-x-52 opacity-20 pointer-events-none">
        <div class="blur-[120px] h-80 bg-gradient-to-br from-blue-900 to-transparent"></div>
        <div class="blur-[120px] h-60 bg-gradient-to-r from-[#FF2D55] to-transparent opacity-10"></div>
    </div>

    <Container>
        <div class="relative pt-40 pb-20">
            
            <!-- GRIGLIA GRAFICA POTENZIATA -->
            <div class="flex flex-col lg:flex-row items-center justify-center gap-2 lg:gap-10">
                
                <!-- LATO SINISTRO: SCHERMI GRANDI -->
                <div class="hidden lg:block w-[30%] perspective-left">
                    <div class="screen-box border-[#00E5FF]/40 shadow-[0_0_50px_rgba(0,229,255,0.2)]">
                        <img src="/player-full.png" class="slide-img anim-delay-0" alt="Player" />
                        <img src="/tag%20mute.jpg" class="slide-img anim-delay-4" alt="Tag Mute" />
                        <img src="/dashboard.jpg" class="slide-img anim-delay-8" alt="Dashboard" />
                        <img src="/filler.jpg" class="slide-img anim-delay-12" alt="Filler" />
                        <div class="screen-overlay"></div>
                        <p class="screen-label text-[#00E5FF]">COMMAND CONSOLE</p>
                    </div>
                </div>

                <!-- CENTRO: LOGO -->
                <div class="relative z-10 w-full lg:w-[40%] text-center group">
                    <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-[#00E5FF] to-[#FF2D55] blur-[100px] opacity-20 animate-pulse"></div>
                    <img 
                        src="/logo-platinum.png" 
                        alt="Logo Platinum" 
                        class="relative z-10 mx-auto transition-transform duration-1000 group-hover:scale-105" 
                        style="width: 420px; max-width: 85vw; height: auto; filter: drop-shadow(0 0 50px rgba(0,229,255,0.4));"
                    />
                </div>

                <!-- LATO DESTRO: SCHERMI GRANDI -->
                <div class="hidden lg:block w-[30%] perspective-right">
                    <div class="screen-box border-[#FF2D55]/40 shadow-[0_0_50px_rgba(255,45,85,0.2)]">
                        <img src="/web.jpg" class="slide-img anim-delay-0" alt="Web App" />
                        <img src="/dj%20virtuale.jpg" class="slide-img anim-delay-4" alt="DJ Virtuale" />
                        <img src="/prenotazioni%20e%20upload.jpg" class="slide-img anim-delay-8" alt="Upload" />
                        <img src="/2%20monitor.jpg" class="slide-img anim-delay-12" alt="Dual Monitor" />
                        <div class="screen-overlay"></div>
                        <p class="screen-label text-[#FF2D55]">SMART INTERACTION</p>
                    </div>
                </div>

            </div>

            <!-- TESTI BILANCIATI E PROFESSIONALI -->
            <div class="text-center mt-20">
                <div class="max-w-4xl mx-auto">
                    <h2 class="text-[#FF2D55] font-black text-lg md:text-xl uppercase tracking-[0.5em] mb-6 italic opacity-90">
                        FERMA TUTTO!!
                    </h2>
                    <h1 class="text-white font-black text-3xl md:text-5xl uppercase italic tracking-tighter leading-tight mb-8">
                        IL KARAOKE CHE CONOSCI <br/>
                        <span class="text-[#00E5FF] drop-shadow-[0_0_15px_rgba(0,229,255,0.5)]">LO ABBIAMO REINVENTATO.</span>
                    </h1>
                    
                    <p class="text-gray-400 text-base md:text-lg font-light leading-relaxed mb-12 italic max-w-2xl mx-auto">
                        "Basta foglietti illeggibili, basi di scarsa qualità e tempi morti. <br class="hidden md:block"/> 
                        È ora di cambiare galassia."
                    </p>

                    <!-- BOX MANIFESTO PIÙ DISCRETO -->
                    <div class="inline-block border border-[#FFD700]/20 p-6 bg-[#FFD700]/5 rounded-2xl mb-16 max-w-2xl">
                        <h3 class="text-xl md:text-2xl font-black text-white uppercase italic tracking-tighter mb-3">
                            FINE DELLA SCHIAVITÙ PROPRIETARIA.
                        </h3>
                        <p class="text-gray-400 text-sm md:text-base leading-relaxed">
                            Crea le tue basi con l'IA e usale su <span class="text-white font-bold underline decoration-[#FFD700]">qualsiasi player del mondo</span>. Tu sei il padrone della tua musica.
                        </p>
                    </div>
                </div>

                <!-- PULSANTI -->
                <div class="flex flex-wrap justify-center gap-y-4 gap-x-6 mb-12">
                    <a href="#" class="btn-platinum-green"><span>SCARICA SETUP</span></a>
                    <a href="#" class="btn-platinum-cyan"><span>INSTALLA MOTORE IA</span></a>
                </div>

                <p class="text-gray-600 text-[9px] uppercase tracking-[0.6em] font-bold">
                    MP4 • AVI • MKV • MP3+G • CDG • KFN • ZIP
                </p>
            </div>

        </div>
    </Container>
</div>

<style>
    /* SCHERMI LATERALI PIÙ GRANDI */
    .screen-box {
        @apply relative w-full aspect-video rounded-xl border-2 overflow-hidden bg-[#0d0d0d];
    }
    .screen-overlay {
        @apply absolute inset-0 bg-gradient-to-t from-black/90 via-transparent to-black/20 pointer-events-none;
    }
    .screen-label {
        @apply absolute bottom-2 left-3 text-[9px] font-black uppercase tracking-[0.3em];
    }

    /* ANIMAZIONE */
    .slide-img { 
        @apply absolute inset-0 w-full h-full object-cover opacity-0; 
        animation: cycleFour 16s infinite; 
    }
    .anim-delay-0 { animation-delay: 0s; }
    .anim-delay-4 { animation-delay: 4s; }
    .anim-delay-8 { animation-delay: 8s; }
    .anim-delay-12 { animation-delay: 12s; }

    @keyframes cycleFour {
        0%, 20% { opacity: 1; }
        25%, 100% { opacity: 0; }
    }

    /* PROSPETTIVA */
    .perspective-left { transform: perspective(1500px) rotateY(15deg); }
    .perspective-right { transform: perspective(1500px) rotateY(-15deg); }

    /* PULSANTI COMPATTI */
    .btn-platinum-green { @apply relative flex h-12 w-full items-center justify-center px-8 transition-all duration-300 sm:w-max border-2 border-[#00E676] bg-[#00E676] text-black font-black uppercase tracking-widest text-sm hover:shadow-[0_0_40px_rgba(0,230,118,0.5)] hover:scale-105; }
    .btn-platinum-cyan { @apply relative flex h-12 w-full items-center justify-center px-8 transition-all duration-300 sm:w-max border-2 border-[#00E5FF] text-[#00E5FF] font-black uppercase tracking-widest text-sm hover:bg-[#00E5FF]/10 hover:shadow-[0_0_30px_rgba(0,229,255,0.3)] hover:scale-105; }
</style>
