---
import Container from "./Container.astro"
---

<div class="relative bg-[#050505] overflow-hidden" id="home">
    <!-- SFONDO HI-TECH -->
    <div aria-hidden="true" class="absolute inset-0 grid grid-cols-2 -space-x-52 opacity-30">
        <div class="blur-[120px] h-80 bg-gradient-to-br from-blue-900 to-transparent"></div>
        <div class="blur-[120px] h-60 bg-gradient-to-r from-[#FF2D55] to-transparent opacity-10"></div>
    </div>

    <Container>
        <!-- SPAZIO SUPERIORE (pt-52) PER STACCARE DAL MENU -->
        <div class="relative pt-52 pb-20 ml-auto">
            <div class="lg:w-2/3 text-center mx-auto">
                
                <!-- LOGO CENTRALE CON GLOW NEON -->
                <div class="relative inline-block mb-16">
                    <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-[#00E5FF] to-[#FF2D55] blur-3xl opacity-30 animate-pulse"></div>
                    
                    <img 
                        src="/logo-platinum.png" 
                        alt="YouTube Karaoke Player Pro Logo" 
                        class="relative z-10 w-64 h-64 md:w-80 md:h-80 mx-auto drop-shadow-[0_0_40px_rgba(0,229,255,0.4)]"
                    />
                </div>

                <!-- TITOLO CON COLORI NEON ESATTI DAL SOFTWARE -->
                <h1 class="font-black text-5xl md:text-6xl uppercase italic tracking-tighter leading-none text-white">
                    <span class="text-[#FF0000] drop-shadow-[0_0_10px_rgba(255,0,0,0.6)]">YouTube</span> 
                    <span class="text-[#FFD700] drop-shadow-[0_0_10px_rgba(255,215,0,0.6)]">Karaoke</span> <br/>
                    <span class="text-[#FF2D55] drop-shadow-[0_0_15px_rgba(255,45,85,0.8)]">Player</span> 
                    <span class="text-[#00E5FF] drop-shadow-[0_0_15px_rgba(0,229,255,0.8)]">Pro</span>
                </h1>

                <p class="mt-8 text-gray-400 text-xl md:text-2xl font-light leading-relaxed">
                    L'unica regia professionale potenziata dall'Intelligenza Artificiale. <br/>
                    <span class="text-[#00E5FF] font-bold">Separazione tracce NVIDIA</span> | 
                    <span class="text-[#FF2D55] font-bold">Radar RMS</span> | 
                    <span class="text-[#FFD700] font-bold">Smart Booking QR</span>
                </p>

                <!-- PULSANTI STILE CONSOLE -->
                <div class="mt-14 flex flex-wrap justify-center gap-y-4 gap-x-6">
                    <a href="#" class="btn-platinum-green">
                        <span class="relative z-10">1. Scarica Setup Player</span>
                    </a>
                    <a href="#" class="btn-platinum-cyan">
                        <span class="relative z-10">2. Installa Motore IA</span>
                    </a>
                </div>
            </div>
        </div>
    </Container>
</div>

<style>
    .btn-platinum-green {
        @apply relative flex h-14 w-full items-center justify-center px-8 transition-all duration-300 sm:w-max border-2 border-[#00E676] bg-[#00E676] text-black font-black uppercase tracking-widest hover:shadow-[0_0_40px_rgba(0,230,118,0.6)] hover:scale-105;
    }
    .btn-platinum-cyan {
        @apply relative flex h-14 w-full items-center justify-center px-8 transition-all duration-300 sm:w-max border-2 border-[#00E5FF] text-[#00E5FF] font-black uppercase tracking-widest hover:bg-[#00E5FF]/10 hover:shadow-[0_0_40px_rgba(0,229,255,0.4)] hover:scale-105;
    }
</style>
