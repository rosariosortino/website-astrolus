---
// src/components/HeroSection.astro
import Container from "./Container.astro"
import languages from "../languages.json"

// Recupera la lingua passata come proprietà dal "regista" (index.astro)
const { lang = "it" } = Astro.props;
const t = languages[lang] || languages["it"];
---
<div class="relative bg-[#050505] overflow-hidden" id="home">
    <!-- SFONDO AMBIENTALE -->
    <div class="absolute inset-0 grid grid-cols-2 -space-x-52 opacity-20 pointer-events-none">
        <div class="blur-[120px] h-80 bg-gradient-to-br from-blue-900 to-transparent"></div>
        <div class="blur-[120px] h-60 bg-gradient-to-r from-[#FF2D55] to-transparent opacity-10"></div>
    </div>

    <!-- CONTAINER ULTRA-WIDE PER LA MASSIMA ESTENSIONE -->
    <div class="w-full max-w-[1920px] mx-auto px-4 lg:px-12">
        <div class="relative pt-32 pb-20">
            
            <!-- GRIGLIA A 3 COLONNE PERFETTAMENTE SIMMETRICA -->
            <div class="grid grid-cols-1 lg:grid-cols-[1fr_auto_1fr] items-center gap-8 lg:gap-16">
                
                <!-- MONITOR SINISTRO (SPINTO A SINISTRA) -->
                <div class="hidden lg:block perspective-left">
                    <div class="screen-box border-[#00E5FF]/40 shadow-[0_0_80px_rgba(0,229,255,0.2)]">
                        <img src="/player-full.png" class="slide-img anim-delay-0" alt="Player" />
                        <img src="/tag%20mute.jpg" class="slide-img anim-delay-4" alt="Tag Mute" />
                        <img src="/dashboard.jpg" class="slide-img anim-delay-8" alt="Dashboard" />
                        <img src="/filler.jpg" class="slide-img anim-delay-12" alt="Filler" />
                        <div class="screen-overlay"></div>
                        <p class="screen-label text-[#00E5FF]">{t.cat_console}</p>
                    </div>
                </div>

                <!-- LOGO CENTRALE (IL PERNO) -->
                <div class="relative z-10 w-[300px] md:w-[400px] lg:w-[450px] mx-auto group">
                    <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-[#00E5FF] to-[#FF2D55] blur-[100px] opacity-30 animate-pulse"></div>
                    <img 
                        src="/logo-platinum.png" 
                        alt="Logo Platinum" 
                        class="relative z-10 mx-auto transition-transform duration-1000 group-hover:scale-110" 
                        style="filter: drop-shadow(0 0 50px rgba(0,229,255,0.5));"
                    />
                </div>

                <!-- MONITOR DESTRO (SPINTO A DESTRA) -->
                <div class="hidden lg:block perspective-right">
                    <div class="screen-box border-[#FF2D55]/40 shadow-[0_0_80px_rgba(255,45,85,0.2)]">
                        <img src="/web.jpg" class="slide-img anim-delay-0" alt="Web App" />
                        <img src="/dj%20virtuale.jpg" class="slide-img anim-delay-4" alt="DJ Virtuale" />
                        <img src="/prenotazioni%20e%20upload.jpg" class="slide-img anim-delay-8" alt="Upload" />
                        <img src="/2%20monitor.jpg" class="slide-img anim-delay-12" alt="Dual Monitor" />
                        <div class="screen-overlay"></div>
                        <p class="screen-label text-[#FF2D55] right-6 left-auto">{t.feat_booking_title}</p>
                    </div>
                </div>

            </div>

            <!-- TESTI E MANIFESTO TRADOTTI -->
            <div class="text-center mt-24">
                <div class="max-w-4xl mx-auto">
                    <h2 class="text-[#FF2D55] font-black text-lg md:text-xl uppercase tracking-[0.5em] mb-6 italic opacity-90">
                        {t.hero_stop}
                    </h2>
                    <h1 class="text-white font-black text-4xl md:text-6xl uppercase italic tracking-tighter leading-tight mb-8">
                        {t.hero_title} <br/>
                        <span class="text-[#00E5FF] drop-shadow-[0_0_15px_rgba(0,229,255,0.5)]">{t.hero_accent}</span>
                    </h1>
                    
                    <p class="text-gray-400 text-base md:text-xl font-light leading-relaxed mb-12 italic max-w-2xl mx-auto">
                        {t.hero_quote}
                    </p>

                    <div class="inline-block border border-[#FFD700]/20 p-8 bg-[#FFD700]/5 rounded-3xl mb-16 max-w-2xl">
                        <h3 class="text-xl md:text-2xl font-black text-white uppercase italic tracking-tighter mb-3">
                            {t.manifesto_title}
                        </h3>
                        <p class="text-gray-400 text-sm md:text-base leading-relaxed">
                            {t.manifesto_text}
                        </p>
                    </div>
                </div>

                <!-- PULSANTI TRADOTTI -->
                <div class="flex flex-wrap justify-center gap-y-4 gap-x-6 mb-12">
                    <a href="#" class="btn-platinum-green"><span>{t.btn_setup}</span></a>
                    <a href="#" class="btn-platinum-cyan"><span>{t.btn_ia}</span></a>
                </div>

                <p class="text-gray-600 text-[10px] uppercase tracking-[0.6em] font-bold">
                    MP4 • AVI • MKV • MP3+G • CDG • KFN • ZIP
                </p>
            </div>

        </div>
    </div>
</div>

<style>
    /* MONITOR LATERALI IMMENSI E LEGGIBILI */
    .screen-box {
        @apply relative w-full aspect-video rounded-[2rem] border-2 overflow-hidden bg-[#0d0d0d];
    }
    .screen-overlay {
        @apply absolute inset-0 bg-gradient-to-t from-black/95 via-transparent to-black/10 pointer-events-none;
    }
    .screen-label {
        @apply absolute bottom-6 left-8 text-[12px] font-black uppercase tracking-[0.5em];
    }

    /* ANIMAZIONE FLUIDA */
    .slide-img { 
        @apply absolute inset-0 w-full h-full object-cover opacity-0 transition-all duration-1000; 
        animation: cycleFour 16s infinite; 
    }
    .anim-delay-0 { animation-delay: 0s; }
    .anim-delay-4 { animation-delay: 4s; }
    .anim-delay-8 { animation-delay: 8s; }
    .anim-delay-12 { animation-delay: 12s; }

    @keyframes cycleFour {
        0%, 20% { opacity: 1; transform: scale(1); }
        25%, 100% { opacity: 0; transform: scale(1.05); }
    }

    /* PROSPETTIVA 3D BILANCIATA PER LA MASSIMA GRANDEZZA */
    .perspective-left { transform: perspective(2000px) rotateY(10deg); }
    .perspective-right { transform: perspective(2000px) rotateY(-10deg); }

    /* PULSANTI */
    .btn-platinum-green { @apply relative flex h-14 w-full items-center justify-center px-10 transition-all duration-300 sm:w-max border-2 border-[#00E676] bg-[#00E676] text-black font-black uppercase tracking-widest text-base hover:shadow-[0_0_50px_rgba(0,230,118,0.6)] hover:scale-105; }
    .btn-platinum-cyan { @apply relative flex h-16 w-full items-center justify-center px-10 transition-all duration-300 sm:w-max border-2 border-[#00E5FF] text-[#00E5FF] font-black uppercase tracking-widest text-base hover:bg-[#00E5FF]/10 hover:shadow-[0_0_40px_rgba(0,229,255,0.4)] hover:scale-105; }
</style>
