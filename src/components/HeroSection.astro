---
import Container from "./Container.astro"
---
<div class="relative bg-[#050505] overflow-hidden" id="home">
    <div class="absolute inset-0 grid grid-cols-2 -space-x-52 opacity-30 pointer-events-none">
        <div class="blur-[120px] h-80 bg-gradient-to-br from-blue-900 to-transparent"></div>
        <div class="blur-[120px] h-60 bg-gradient-to-r from-[#FF2D55] to-transparent opacity-10"></div>
    </div>

    <Container>
        <div class="relative pt-48 pb-20 ml-auto">
            <div class="lg:w-full text-center mx-auto">
                
                <!-- LOGO MONUMENTALE -->
                <div class="relative inline-block mb-12 group">
                    <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-[#00E5FF] to-[#FF2D55] blur-[100px] opacity-20 animate-pulse group-hover:opacity-40 transition-opacity duration-700"></div>
                    <img src="/logo-platinum.png" alt="Logo" class="relative z-10 mx-auto transition-all duration-1000 group-hover:scale-105" style="width: 480px; max-width: 90vw; height: auto; filter: drop-shadow(0 0 60px rgba(0,229,255,0.4));"/>
                </div>

                <div class="max-w-5xl mx-auto mb-16">
                    <h1 class="text-[#FF2D55] font-black text-4xl md:text-6xl uppercase italic tracking-tighter mb-4 animate-pulse">
                        FERMA TUTTO!!
                    </h1>
                    <h2 class="text-white font-black text-5xl md:text-8xl uppercase italic tracking-tighter leading-none mb-8">
                        IL KARAOKE CHE CONOSCI <br/>
                        <span class="text-[#00E5FF]">LO ABBIAMO REINVENTATO.</span>
                    </h2>
                    
                    <p class="text-gray-400 text-xl md:text-3xl font-light leading-relaxed mb-10 italic">
                        "Basta foglietti illeggibili, basi di scarsa qualità e tempi morti che uccidono la serata. <br class="hidden md:block"/> 
                        È ora di cambiare galassia."
                    </p>

                    <div class="inline-block border-2 border-[#FFD700] p-6 bg-[#FFD700]/5 rounded-2xl mb-12">
                        <h2 class="text-3xl md:text-5xl font-black text-white uppercase italic tracking-tighter mb-4 leading-tight">
                            FINE DELLA SCHIAVITÙ. <br/>
                            <span class="text-[#00E5FF]">BENVENUTO NELLO STANDARD LIBERO.</span>
                        </h2>
                        <p class="text-gray-400 text-lg md:text-xl max-w-3xl mx-auto leading-relaxed">
                            Basta abbonamenti infiniti. Platinum Karaoke Pro crea basi professionali con <span class="text-white font-bold underline decoration-[#FFD700]">Standard Libero</span>: le crei una volta, le usi ovunque.
                        </p>
                    </div>
                </div>

                <div class="flex flex-wrap justify-center gap-y-6 gap-x-8 mb-8">
                    <a href="#" class="btn-green"><span>SCARICA SETUP PLAYER</span></a>
                    <a href="#" class="btn-cyan"><span>INSTALLA MOTORE IA</span></a>
                </div>

                <!-- LISTA FORMATI SUPPORTATI -->
                <div class="mb-24">
                    <p class="text-gray-500 text-xs md:text-sm uppercase tracking-[0.3em] font-bold">
                        SUPPORTA: MP4 • AVI • MKV • MP3+G • CDG • KFN • MP3+TESTO (LRC/ASS) • ZIP
                    </p>
                </div>

                <!-- SHOWCASE PLAYER -->
                <div class="relative group max-w-6xl mx-auto rounded-2xl border border-white/10 overflow-hidden shadow-2xl bg-[#0d0d0d]" id="showcase">
                    <div class="bg-[#1a1a1a] px-4 py-2 border-b border-white/5 flex items-center space-x-2">
                        <div class="w-3 h-3 rounded-full bg-[#FF1744]"></div>
                        <div class="w-3 h-3 rounded-full bg-[#FFD700]"></div>
                        <div class="w-3 h-3 rounded-full bg-[#00E676]"></div>
                        <span class="text-[10px] text-gray-500 uppercase font-black tracking-widest pl-4 italic">Platinum Core Engine - Command Center v16.0</span>
                    </div>
                    <img src="/player-full.png" alt="Console" class="w-full h-auto opacity-95 group-hover:opacity-100 transition-opacity duration-500"/>
                </div>
            </div>
        </div>
    </Container>
</div>
<style>
    .btn-green { @apply relative flex h-16 w-full items-center justify-center px-10 transition-all duration-300 sm:w-max border-2 border-[#00E676] bg-[#00E676] text-black font-black uppercase tracking-widest text-lg hover:shadow-[0_0_50px_rgba(0,230,118,0.6)] hover:scale-110 active:scale-95; }
    .btn-cyan { @apply relative flex h-16 w-full items-center justify-center px-10 transition-all duration-300 sm:w-max border-2 border-[#00E5FF] text-[#00E5FF] font-black uppercase tracking-widest text-lg hover:bg-[#00E5FF]/10 hover:shadow-[0_0_40px_rgba(0,229,255,0.4)] hover:scale-110 active:scale-95; }
</style>
