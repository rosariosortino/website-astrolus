---
import Container from "./Container.astro"
---
<div class="relative bg-[#050505] overflow-hidden" id="home">
    <!-- SFONDO AMBIENTALE NEON -->
    <div class="absolute inset-0 grid grid-cols-2 -space-x-52 opacity-20 pointer-events-none">
        <div class="blur-[120px] h-80 bg-gradient-to-br from-blue-900 to-transparent"></div>
        <div class="blur-[120px] h-60 bg-gradient-to-r from-[#FF2D55] to-transparent opacity-10"></div>
    </div>

    <Container>
        <div class="relative pt-32 pb-20">
            
            <!-- GRIGLIA GRAFICA: PREVIEWS SINISTRA | LOGO | PREVIEWS DESTRA -->
            <div class="flex flex-col lg:flex-row items-center justify-between gap-4">
                
                <!-- LATO SINISTRO: ROTAZIONE 1 (Console & Tools) -->
                <div class="hidden lg:block w-1/4 perspective-left">
                    <div class="screen-box border-[#00E5FF]/30 shadow-[0_0_40px_rgba(0,229,255,0.15)]">
                        <img src="/player-full.png" class="slide-img anim-delay-0" alt="Player" />
                        <img src="/tag%20mute.jpg" class="slide-img anim-delay-4" alt="Tag Mute" />
                        <img src="/dashboard.jpg" class="slide-img anim-delay-8" alt="Dashboard" />
                        <img src="/filler.jpg" class="slide-img anim-delay-12" alt="Filler" />
                        <div class="screen-overlay"></div>
                        <p class="screen-label text-[#00E5FF]">COMMAND CONSOLE</p>
                    </div>
                </div>

                <!-- CENTRO: LOGO MONUMENTALE -->
                <div class="relative z-10 w-full lg:w-2/4 text-center group">
                    <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-[#00E5FF] to-[#FF2D55] blur-[100px] opacity-20 animate-pulse"></div>
                    <img 
                        src="/logo-platinum.png" 
                        alt="Logo Platinum" 
                        class="relative z-10 mx-auto transition-transform duration-1000 group-hover:scale-105" 
                        style="width: 450px; max-width: 85vw; height: auto; filter: drop-shadow(0 0 50px rgba(0,229,255,0.4));"
                    />
                </div>

                <!-- LATO DESTRO: ROTAZIONE 2 (Interaction & Live) -->
                <div class="hidden lg:block w-1/4 perspective-right">
                    <div class="screen-box border-[#FF2D55]/30 shadow-[0_0_40px_rgba(255,45,85,0.15)]">
                        <img src="/web.jpg" class="slide-img anim-delay-0" alt="Web App" />
                        <img src="/dj%20virtuale.jpg" class="slide-img anim-delay-4" alt="DJ Virtuale" />
                        <img src="/prenotazioni%20e%20upload.jpg" class="slide-img anim-delay-8" alt="Upload" />
                        <img src="/2%20monitor.jpg" class="slide-img anim-delay-12" alt="Dual Monitor" />
                        <div class="screen-overlay"></div>
                        <p class="screen-label text-[#FF2D55]">SMART INTERACTION</p>
                    </div>
                </div>

            </div>

            <!-- TESTI E MANIFESTO (MANTENUTI INTEGRALMENTE) -->
            <div class="text-center mt-16">
                <div class="max-w-4xl mx-auto">
                    <h2 class="text-[#FF2D55] font-black text-xl md:text-2xl uppercase tracking-[0.4em] mb-6 italic">
                        FERMA TUTTO!!
                    </h2>
                    <h1 class="text-white font-black text-5xl md:text-7xl lg:text-8xl uppercase italic tracking-tighter leading-[0.85] mb-10">
                        IL KARAOKE CHE CONOSCI <br/>
                        <span class="text-[#00E5FF]">LO ABBIAMO REINVENTATO.</span>
                    </h1>
                    
                    <div class="inline-block border border-[#FFD700]/30 p-8 bg-[#FFD700]/5 rounded-3xl mb-16 max-w-3xl">
                        <h3 class="text-2xl md:text-4xl font-black text-white uppercase italic tracking-tighter mb-4">
                            FINE DELLA SCHIAVITÙ. <br/>
                            <span class="text-[#00E5FF]">BENVENUTO NELLO STANDARD LIBERO.</span>
                        </h3>
                        <p class="text-gray-400 text-lg md:text-xl leading-relaxed">
                            Basta abbonamenti infiniti e formati proprietari obsoleti. Platinum Karaoke Pro crea basi professionali con <span class="text-white font-bold underline decoration-[#FFD700]">Standard Libero</span>: le crei una volta, le usi ovunque.
                        </p>
                    </div>
                </div>

                <!-- PULSANTI AZIONE -->
                <div class="flex flex-wrap justify-center gap-y-6 gap-x-8 mb-12">
                    <a href="#" class="btn-platinum-green"><span>SCARICA SETUP PLAYER</span></a>
                    <a href="#" class="btn-platinum-cyan"><span>INSTALLA MOTORE IA</span></a>
                </div>

                <p class="text-gray-600 text-[10px] md:text-xs uppercase tracking-[0.5em] font-bold">
                    SUPPORTA: MP4 • AVI • MKV • MP3+G • CDG • KFN • MP3+TESTO • ZIP
                </p>
            </div>

        </div>
    </Container>
</div>

<style>
    /* STILE SCHERMI LATERALI */
    .screen-box { @apply relative w-full aspect-[4/3] rounded-2xl border overflow-hidden bg-[#0d0d0d]; }
    .screen-overlay { @apply absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-black/20 pointer-events-none; }
    .screen-label { @apply absolute bottom-3 left-4 text-[10px] font-black uppercase tracking-[0.2em]; }

    /* ANIMAZIONE CICLICA PER 4 IMMAGINI (16 secondi totale) */
    .slide-img { 
        @apply absolute inset-0 w-full h-full object-cover opacity-0; 
        animation: cycleFour 16s infinite; 
    }
    .anim-delay-0 { animation-delay: 0s; }
    .anim-delay-4 { animation-delay: 4s; }
    .anim-delay-8 { animation-delay: 8s; }
    .anim-delay-12 { animation-delay: 12s; }

    @keyframes cycleFour {
        0%, 20% { opacity: 1; transform: scale(1); }
        25%, 100% { opacity: 0; transform: scale(1.05); }
    }

    /* PROSPETTIVA 3D */
    .perspective-left { transform: perspective(1200px) rotateY(20deg) scale(0.9); }
    .perspective-right { transform: perspective(1200px) rotateY(-20deg) scale(0.9); }

    /* PULSANTI LED */
    .btn-platinum-green { @apply relative flex h-16 w-full items-center justify-center px-10 transition-all duration-300 sm:w-max border-2 border-[#00E676] bg-[#00E676] text-black font-black uppercase tracking-widest text-lg hover:shadow-[0_0_50px_rgba(0,230,118,0.6)] hover:scale-110 active:scale-95; }
    .btn-platinum-cyan { @apply relative flex h-16 w-full items-center justify-center px-10 transition-all duration-300 sm:w-max border-2 border-[#00E5FF] text-[#00E5FF] font-black uppercase tracking-widest text-lg hover:bg-[#00E5FF]/10 hover:shadow-[0_0_40px_rgba(0,229,255,0.4)] hover:scale-110 active:scale-95; }
</style>
