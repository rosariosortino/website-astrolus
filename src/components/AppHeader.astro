---
// src/components/AppHeader.astro
const { lang = "it", t } = Astro.props;

// Link del menu - Possiamo lasciarli così o tradurli nel JSON in futuro
const menuItems = [
  { name: "FUNZIONI", href: "#features" },
  { name: "SOFTWARE", href: "#download" },
  { name: "SUPPORTO", href: "mailto:rosario.sortino@gmail.com" },
];

const languages = [
  { code: "it", label: "IT" },
  { code: "es", label: "ES" },
  { code: "en", label: "EN" },
  { code: "fr", label: "FR" },
  { code: "de", label: "DE" },
  { code: "pt", label: "PT" },
];
---

<header class="fixed top-0 w-full z-50 bg-[#050505]/90 backdrop-blur-md border-b border-white/5">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    
    {/* LOGO - Punta sempre alla home della lingua corrente */}
    <a href={`/${lang}/`} class="flex items-center gap-2">
      <span class="text-xl font-black italic text-white tracking-tighter uppercase">
        PLATINUM<span class="text-[#00E5FF]">PROJECT</span>
      </span>
    </a>

    {/* MENU LINKS - Visibili da tablet in su */}
    <div class="hidden md:flex items-center gap-8">
      {menuItems.map(item => (
        <a href={item.href} class="text-[11px] font-bold tracking-widest text-gray-400 hover:text-[#00E5FF] transition uppercase">
          {item.name}
        </a>
      ))}
    </div>

    {/* ACTIONS: Language Selector & Buy Button */}
    <div class="flex items-center gap-4">
      
      {/* SELETTORE LINGUE DINAMICO */}
      <div class="relative group">
        <button class="text-[11px] font-bold text-white border border-white/20 px-3 py-1.5 rounded bg-white/5 hover:border-[#00E5FF] transition flex items-center gap-2 uppercase">
          {lang} <span class="text-[#00E5FF] text-[8px]">▼</span>
        </button>
        
        {/* Dropdown che appare al passaggio del mouse */}
        <div class="absolute right-0 mt-2 w-24 bg-[#0f0f0f] border border-white/10 rounded-lg hidden group-hover:block overflow-hidden shadow-2xl z-[100]">
          {languages.map(l => (
            <a 
              href={`/${l.code}/`} 
              class={`block px-4 py-3 text-[10px] font-bold transition-all border-b border-white/5 last:border-0 ${lang === l.code ? 'text-[#00E5FF] bg-white/5' : 'text-gray-400 hover:bg-[#00E5FF] hover:text-black'}`}
            >
              {l.label}
            </a>
          ))}
        </div>
      </div>

      {/* TASTO ACQUISTA ROSSO NEON */}
      <a href="#buy" class="px-5 py-2.5 bg-[#FF3366] text-white text-[11px] font-black italic uppercase rounded-full shadow-[0_0_15px_rgba(255,51,102,0.4)] hover:scale-105 transition active:scale-95">
        ACQUISTA LICENZA
      </a>
    </div>
  </nav>
</header>
