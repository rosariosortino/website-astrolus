---
const { lang, t } = Astro.props;

// Definiamo i link del menu (usiamo le chiavi del JSON se vuoi, o testi semplici)
const menuItems = [
  { name: "FUNZIONI", href: "#features" },
  { name: "SOFTWARE", href: "#download" },
  { name: "SUPPORTO", href: "mailto:rosario.sortino@gmail.com" },
];

const languages = [
  { code: "it", label: "IT" },
  { code: "es", label: "ES" },
  { code: "en", label: "EN" },
  { code: "fr", label: "FR" },
  { code: "de", label: "DE" },
  { code: "pt", label: "PT" },
];
---

<header class="fixed top-0 w-full z-50 bg-[#050505]/80 backdrop-blur-md border-b border-white/5">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    
    {/* LOGO */}
    <a href={`/${lang}`} class="flex items-center gap-2">
      <span class="text-xl font-black italic text-white tracking-tighter">
        PLATINUM<span class="text-[#00E5FF]">PROJECT</span>
      </span>
    </a>

    {/* MENU LINKS (Desktop) */}
    <div class="hidden md:flex items-center gap-8">
      {menuItems.map(item => (
        <a href={item.href} class="text-xs font-bold text-gray-400 hover:text-[#00E5FF] transition">
          {item.name}
        </a>
      ))}
    </div>

    {/* ACTIONS: Language & Buy */}
    <div class="flex items-center gap-4">
      
      {/* Selettore Lingue */}
      <div class="relative group">
        <button class="text-xs font-bold text-white border border-white/20 px-3 py-1 rounded hover:bg-white/10 flex items-center gap-1 uppercase">
          {lang} ▼
        </button>
        <div class="absolute right-0 mt-2 w-20 bg-[#111] border border-white/10 rounded-lg hidden group-hover:block overflow-hidden shadow-2xl">
          {languages.map(l => (
            <a href={`/${l.code}`} class="block px-4 py-2 text-xs font-bold text-gray-400 hover:bg-[#00E5FF] hover:text-black transition">
              {l.label}
            </a>
          ))}
        </div>
      </div>

      {/* Tasto Acquista */}
      <a href="#buy" class="px-5 py-2 bg-[#FF3366] text-white text-xs font-black italic uppercase rounded-full shadow-[0_0_15px_rgba(255,51,102,0.4)] hover:scale-105 transition active:scale-95">
        ACQUISTA LICENZA
      </a>
    </div>
  </nav>
</header>
