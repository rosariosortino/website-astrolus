---
const { lang = "it", t } = Astro.props;

// I link che erano spariti
const menuItems = [
  { name: "FUNZIONI", href: "#features" },
  { name: "SOFTWARE", href: "#download" },
  { name: "SUPPORTO", href: "mailto:rosario.sortino@gmail.com" },
];

const languages = [
  { code: "it", label: "IT" },
  { code: "es", label: "ES" },
  { code: "en", label: "EN" },
  { code: "fr", label: "FR" },
  { code: "de", label: "DE" },
  { code: "pt", label: "PT" },
];
---
<header class="fixed top-0 w-full z-50 bg-[#050505]/90 backdrop-blur-md border-b border-white/5">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    
    <a href="/" class="text-xl font-black italic text-white tracking-tighter uppercase">
        PLATINUM<span class="text-[#00E5FF]">PROJECT</span>
    </a>

    {/* LINK CENTRALI (RIPRISTINATI) */}
    <div class="hidden md:flex items-center gap-8">
      {menuItems.map(item => (
        <a href={item.href} class="text-[11px] font-bold tracking-widest text-gray-400 hover:text-[#00E5FF] transition uppercase">
          {item.name}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-6">
      {/* SELETTORE LINGUA */}
      <div class="relative group">
        <button class="text-[11px] font-bold text-white border border-white/20 px-3 py-1.5 rounded bg-white/5 uppercase">
          {lang} ▼
        </button>
        <div class="absolute right-0 mt-2 w-24 bg-[#0f0f0f] border border-white/10 rounded-lg hidden group-hover:block overflow-hidden shadow-2xl z-[100]">
          {languages.map(l => (
            <a href={l.code === 'it' ? '/' : `/${l.code}`} class="block px-4 py-3 text-[10px] font-bold text-gray-400 hover:bg-[#00E5FF] hover:text-black transition-all">
              {l.label}
            </a>
          ))}
        </div>
      </div>

      <a href="#buy" class="px-5 py-2.5 bg-[#FF3366] text-white text-[11px] font-black italic uppercase rounded-full shadow-[0_0_15px_rgba(255,51,102,0.4)] hover:scale-105 transition">
        ACQUISTA LICENZA
      </a>
    </div>
  </nav>
</header>
