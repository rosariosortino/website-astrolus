---
// src/components/AppHeader.astro
const { lang = "it", t } = Astro.props;

const menuItems = [
  { name: "FUNZIONI", href: "#features" },
  { name: "SOFTWARE", href: "#download" },
  { name: "SUPPORTO", href: "mailto:rosario.sortino@gmail.com" },
];

const languages = [
  { code: "it", label: "IT" },
  { code: "es", label: "ES" },
  { code: "en", label: "EN" },
  { code: "fr", label: "FR" },
  { code: "de", label: "DE" },
  { code: "pt", label: "PT" },
];
---

<header class="fixed top-0 w-full z-50 bg-[#050505]/90 backdrop-blur-md border-b border-white/5">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    
    {/* LOGO */}
    <a href={lang === 'it' ? '/' : `/${lang}`} class="flex items-center">
      <span class="text-xl font-black italic text-white tracking-tighter uppercase">
        PLATINUM<span class="text-[#00E5FF]">PROJECT</span>
      </span>
    </a>

    {/* LINK CENTRALI (RIPRISTINATI) */}
    <div class="hidden md:flex items-center gap-8">
      {menuItems.map(item => (
        <a href={item.href} class="text-[11px] font-bold tracking-widest text-gray-400 hover:text-[#00E5FF] transition uppercase">
          {item.name}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-6">
      
      {/* SELETTORE LINGUA CON FIX PER IL "BUCO" INVISIBILE */}
      <div class="relative group py-2 -my-2"> 
        <button class="text-[11px] font-bold text-white border border-white/20 px-3 py-1.5 rounded bg-white/5 uppercase flex items-center gap-1">
          {lang} <span class="text-[8px] text-[#00E5FF]">▼</span>
        </button>
        
        {/* Dropdown menu - Ora attaccato senza spazi vuoti */}
        <div class="absolute right-0 top-full pt-1 w-24 hidden group-hover:block z-[100]">
            <div class="bg-[#0f0f0f] border border-white/10 rounded-lg overflow-hidden shadow-2xl">
              {languages.map(l => (
                <a 
                  href={l.code === 'it' ? '/' : `/${l.code}`} 
                  class="block px-4 py-3 text-[10px] font-bold text-gray-400 hover:bg-[#00E5FF] hover:text-black transition-all border-b border-white/5 last:border-0 text-center"
                >
                  {l.label}
                </a>
              ))}
            </div>
        </div>
      </div>

      {/* TASTO ACQUISTA */}
      <a href="#buy" class="px-5 py-2.5 bg-[#FF3366] text-white text-[11px] font-black italic uppercase rounded-full shadow-[0_0_15px_rgba(255,51,102,0.4)] hover:scale-105 transition">
        ACQUISTA LICENZA
      </a>
    </div>
  </nav>
</header>
