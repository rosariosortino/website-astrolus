---
import Container from "./Container.astro";
---

<header>
    <nav class="z-50 w-full absolute border-b border-white/5 bg-[#050505]/50 backdrop-blur-md">
        <Container>
            <div class="relative flex flex-wrap items-center justify-between gap-6 py-3 md:gap-0 md:py-4">
                <div class="relative z-20 flex w-full justify-between md:px-0 lg:w-max">
                    <a href="/#home" aria-label="logo" class="flex items-center space-x-2">
                        <span class="text-lg font-black tracking-tighter uppercase italic text-white">
                            Platinum <span class="text-[#00E5FF]">Project</span>
                        </span>
                    </a>
                </div>
                <div class="flex-wrap items-center justify-end w-full gap-6 flex">
                    <div class="text-gray-300 lg:pr-4">
                        <ul class="flex flex-row gap-6 text-sm font-bold uppercase tracking-widest">
                            <li><a href="#features" class="hover:text-[#00E5FF] transition">Funzioni</a></li>
                            <li><a href="mailto:rosario.sortino@gmail.com" class="hover:text-[#FF2D55] transition">Supporto</a></li>
                        </ul>
                    </div>
                    <a href="#" class="relative flex h-10 items-center justify-center px-6 before:absolute before:inset-0 before:rounded-full before:bg-[#E91E63] before:transition before:duration-300 hover:before:scale-105 active:duration-75 active:before:scale-95">
                        <span class="relative text-sm font-bold text-white uppercase">Acquista Licenza</span>
                    </a>
                </div>
            </div>
        </Container>
    </nav>
</header>
