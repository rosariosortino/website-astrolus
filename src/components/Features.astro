---
const { t } = Astro.props;

// Definiamo i colori dei bordi per ogni categoria come nei tuoi screenshot
const categories = [
  {
    title: t.cat_console,
    borderColor: "border-l-[6px] border-purple-600",
    items: [
      { title: t.feat_radar_title, desc: t.feat_radar_desc, icon: "📡" },
      { title: t.feat_tag_title, desc: t.feat_tag_desc, icon: "🔇" },
      { title: t.feat_billboard_title, desc: t.feat_billboard_desc, icon: "📺" },
      { title: t.feat_pitch_title, desc: t.feat_pitch_desc, icon: "🎹" },
    ]
  },
  {
    title: t.cat_audio,
    borderColor: "border-l-[6px] border-green-500",
    items: [
      { title: t.feat_comp_title, desc: t.feat_comp_desc, icon: "📊" },
      { title: t.feat_filler_title, desc: t.feat_filler_desc, icon: "📻" },
      { title: t.feat_boost_title, desc: t.feat_boost_desc, icon: "🚀" },
    ]
  },
  {
    title: t.cat_mgmt,
    borderColor: "border-l-[6px] border-yellow-500",
    items: [
      { title: t.feat_search_title, desc: t.feat_search_desc, icon: "🔍" },
      { title: t.feat_dj_title, desc: t.feat_dj_desc, icon: "🎙️" },
      { title: t.feat_wizard_title, desc: t.feat_wizard_desc, icon: "🪄" },
      { title: t.feat_udp_title, desc: t.feat_udp_desc, icon: "📊" },
    ]
  },
  {
    title: t.cat_adv,
    borderColor: "border-l-[6px] border-red-600",
    items: [
      { title: t.feat_clinic_title, desc: t.feat_clinic_desc, icon: "🛡️" },
      { title: t.feat_mirror_title, desc: t.feat_mirror_desc, icon: "💾" },
      { title: t.feat_booking_title, desc: t.feat_booking_desc, icon: "🔑" },
      { title: t.feat_watchdog_title, desc: t.feat_watchdog_desc, icon: "🤖" },
    ]
  }
];
---

<section id="features" class="py-20 bg-[#050505]">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="text-center mb-20">
      <h4 class="text-[#00E5FF] font-black uppercase tracking-[0.3em] mb-4 text-sm">{t.arsenal_header}</h4>
      <h2 class="text-5xl md:text-7xl font-black italic text-white uppercase tracking-tighter">
        {t.arsenal_title}
      </h2>
    </div>

    <div class="space-y-20">
      {categories.map((cat) => (
        <div class="space-y-8">
          {/* Titolo Categoria con bordo neon */}
          <h3 class={`text-xl font-black italic uppercase p-4 bg-white/5 ${cat.borderColor} text-white inline-block`}>
            {cat.title}
          </h3>

          {/* Griglia delle Card */}
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            {cat.items.map((item) => (
              <div class="p-8 bg-[#0a0a0a] border border-white/5 hover:border-white/20 transition-all duration-300 flex flex-col items-center text-center group">
                <div class="text-3xl mb-6 group-hover:scale-125 transition-transform duration-300">
                  {item.icon}
                </div>
                <h4 class="text-white font-black italic uppercase text-lg mb-3 tracking-tighter">
                  {item.title}
                </h4>
                <p class="text-gray-500 text-sm leading-relaxed">
                  {item.desc}
                </p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
