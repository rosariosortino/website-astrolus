---
// src/components/Features.astro
// 1. Recuperiamo le traduzioni passate dal file index.astro
const { t } = Astro.props;

// 2. Definiamo la struttura dati: questa logica evita di scrivere 1000 righe di HTML
// rendendo il file leggero e impossibile da "tagliare" per la chat.
const categories = [
  {
    title: t.cat_console,
    borderColor: "border-l-[6px] border-purple-600",
    items: [
      { title: t.feat_radar_title, desc: t.feat_radar_desc, icon: "📡" },
      { title: t.feat_tag_title, desc: t.feat_tag_desc, icon: "🔇" },
      { title: t.feat_billboard_title, desc: t.feat_billboard_desc, icon: "📺" },
      { title: t.feat_pitch_title, desc: t.feat_pitch_desc, icon: "🎹" },
    ]
  },
  {
    title: t.cat_audio,
    borderColor: "border-l-[6px] border-green-500",
    items: [
      { title: t.feat_comp_title, desc: t.feat_comp_desc, icon: "📊" },
      { title: t.feat_filler_title, desc: t.feat_filler_desc, icon: "📻" },
      { title: t.feat_boost_title, desc: t.feat_boost_desc, icon: "🚀" },
    ]
  },
  {
    title: t.cat_mgmt,
    borderColor: "border-l-[6px] border-yellow-500",
    items: [
      { title: t.feat_search_title, desc: t.feat_search_desc, icon: "🔍" },
      { title: t.feat_dj_title, desc: t.feat_dj_desc, icon: "🎙️" },
      { title: t.feat_wizard_title, desc: t.feat_wizard_desc, icon: "🪄" },
      { title: t.feat_udp_title, desc: t.feat_udp_desc, icon: "📊" },
    ]
  },
  {
    title: t.cat_adv,
    borderColor: "border-l-[6px] border-red-600",
    items: [
      { title: t.feat_clinic_title, desc: t.feat_clinic_desc, icon: "🛡️" },
      { title: t.feat_mirror_title, desc: t.feat_mirror_desc, icon: "💾" },
      { title: t.feat_booking_title, desc: t.feat_booking_desc, icon: "🔑" },
      { title: t.feat_watchdog_title, desc: t.feat_watchdog_desc, icon: "🤖" },
    ]
  }
];
---

<section id="features" class="py-24 bg-[#050505]">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    
    {/* INTESTAZIONE SEZIONE: Tecnologia Avanzata + Arsenale */}
    <div class="text-center mb-24">
      <h4 class="text-[#00E5FF] font-black uppercase tracking-[0.4em] mb-4 text-xs italic">
        {t.arsenal_header}
      </h4>
      <h2 class="text-5xl md:text-7xl font-black italic text-white uppercase tracking-tighter leading-none">
        {t.arsenal_title}
      </h2>
    </div>

    {/* LOOP DELLE CATEGORIE (Console, Audio, etc.) */}
    <div class="space-y-24">
      {categories.map((cat) => (
        <div class="group">
          {/* Titolo Categoria con il tuo iconico bordo neon laterale */}
          <h3 class={`text-xl font-black italic uppercase p-4 mb-10 bg-white/5 ${cat.borderColor} text-white inline-block tracking-tight`}>
            {cat.title}
          </h3>

          {/* GRIGLIA CARTE: 4 colonne su desktop, 1 su mobile */}
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {cat.items.map((item) => (
              <div class="p-8 bg-[#0a0a0a] border border-white/5 hover:border-[#00E5FF]/40 transition-all duration-500 flex flex-col items-center text-center rounded-sm">
                
                {/* ICONA */}
                <div class="text-4xl mb-6 grayscale group-hover:grayscale-0 transition duration-500">
                  {item.icon}
                </div>
                
                {/* TITOLO FEAT */}
                <h4 class="text-white font-black italic uppercase text-lg mb-3 tracking-tighter">
                  {item.title}
                </h4>
                
                {/* DESCRIZIONE */}
                <p class="text-gray-500 text-sm leading-relaxed font-medium">
                  {item.desc}
                </p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
