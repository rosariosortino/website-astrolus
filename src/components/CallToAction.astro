---
const { t } = Astro.props;
---

<section class="relative py-20 bg-[#050505] flex flex-col items-center justify-center px-6">
  
  {/* BLOCCO 1: I 4 Motivi per scegliere Platinum */}
  <div class="max-w-4xl w-full mb-16">
    <h3 class="text-3xl font-black text-white text-center mb-10 tracking-widest uppercase">
      {t.why_title}
    </h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {/* Card 1 */}
      <div class="flex items-start gap-4 p-6 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-[#00E5FF]/50 transition duration-300">
        <span class="text-[#00E5FF] text-2xl">✅</span>
        <p class="text-gray-300 font-medium leading-relaxed">{t.why_p1}</p>
      </div>
      {/* Card 2 */}
      <div class="flex items-start gap-4 p-6 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-[#00E5FF]/50 transition duration-300">
        <span class="text-[#00E5FF] text-2xl">✅</span>
        <p class="text-gray-300 font-medium leading-relaxed">{t.why_p2}</p>
      </div>
      {/* Card 3 */}
      <div class="flex items-start gap-4 p-6 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-[#00E5FF]/50 transition duration-300">
        <span class="text-[#00E5FF] text-2xl">✅</span>
        <p class="text-gray-300 font-medium leading-relaxed">{t.why_p3}</p>
      </div>
      {/* Card 4 */}
      <div class="flex items-start gap-4 p-6 rounded-2xl bg-white/[0.02] border border-white/10 hover:border-[#00E5FF]/50 transition duration-300">
        <span class="text-[#00E5FF] text-2xl">✅</span>
        <p class="text-gray-300 font-medium leading-relaxed">{t.why_p4}</p>
      </div>
    </div>
  </div>

  {/* BLOCCO 2: Il Payoff Gigante (Basato sul tuo Screenshot 5) */}
  <div class="w-full max-w-5xl p-10 md:p-16 rounded-[2rem] bg-[#0a0a0a] border border-white/5 shadow-2xl flex flex-col items-center text-center">
    <h2 class="text-4xl md:text-6xl font-black italic text-white tracking-tighter mb-2">
      {t.payoff_1}
    </h2>
    <h2 class="text-4xl md:text-6xl font-black italic text-[#FF3366] tracking-tighter shadow-[#FF3366]/20 drop-shadow-lg">
      {t.payoff_2}
    </h2>
  </div>

</section>
