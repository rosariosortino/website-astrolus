---
// src/components/CallToAction.astro
// Riceviamo l'oggetto traduzioni 't' dal file della pagina (index.astro, es.astro, ecc.)
// Questo garantisce che se sei in /es, 't' conterrà i testi spagnoli.
const { t } = Astro.props;
---

<section class="relative py-24 bg-[#050505] flex flex-col items-center justify-center px-6 overflow-hidden">
  
  {/* SFONDO RADIALE: Crea quell'alone soffuso rosso neon al centro */}
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-[#FF3366]/5 via-transparent to-transparent pointer-events-none"></div>

  {/* BLOCCO 1: I 4 MOTIVI TECNICI */}
  <div class="max-w-5xl w-full mb-24 relative z-10">
    <h3 class="text-3xl md:text-4xl font-black italic text-white text-center mb-16 tracking-[0.2em] uppercase">
      {t.why_title}
    </h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {/* Card 1: 20GB Potenza */}
      <div class="flex items-start gap-5 p-8 rounded-[2rem] bg-white/[0.03] border border-white/10 hover:border-[#00E5FF]/40 transition-all duration-500 group">
        <div class="text-[#00E5FF] text-3xl group-hover:scale-125 transition-transform duration-300">✅</div>
        <p class="text-gray-300 text-lg font-medium leading-relaxed italic">{t.why_p1}</p>
      </div>

      {/* Card 2: Automazione */}
      <div class="flex items-start gap-5 p-8 rounded-[2rem] bg-white/[0.03] border border-white/10 hover:border-[#00E5FF]/40 transition-all duration-500 group">
        <div class="text-[#00E5FF] text-3xl group-hover:scale-125 transition-transform duration-300">✅</div>
        <p class="text-gray-300 text-lg font-medium leading-relaxed italic">{t.why_p2}</p>
      </div>

      {/* Card 3: Cloud & Licenze */}
      <div class="flex items-start gap-5 p-8 rounded-[2rem] bg-white/[0.03] border border-white/10 hover:border-[#00E5FF]/40 transition-all duration-500 group">
        <div class="text-[#00E5FF] text-3xl group-hover:scale-125 transition-transform duration-300">✅</div>
        <p class="text-gray-300 text-lg font-medium leading-relaxed italic">{t.why_p3}</p>
      </div>

      {/* Card 4: Sviluppato da Pro */}
      <div class="flex items-start gap-5 p-8 rounded-[2rem] bg-white/[0.03] border border-white/10 hover:border-[#00E5FF]/40 transition-all duration-500 group">
        <div class="text-[#00E5FF] text-3xl group-hover:scale-125 transition-transform duration-300">✅</div>
        <p class="text-gray-300 text-lg font-medium leading-relaxed italic">{t.why_p4}</p>
      </div>
    </div>
  </div>

  {/* BLOCCO 2: IL PAYOFF MONUMENTALE */}
  <div class="w-full max-w-6xl p-12 md:p-24 rounded-[3rem] bg-[#0a0a0a] border border-white/5 shadow-[0_0_100px_rgba(255,51,102,0.1)] flex flex-col items-center text-center relative overflow-hidden group">
    
    {/* Effetto luce interna che reagisce al mouse */}
    <div class="absolute -top-24 -left-24 w-64 h-64 bg-[#FF3366] opacity-10 blur-[100px] group-hover:opacity-20 transition-opacity duration-700"></div>

    <h2 class="text-4xl md:text-8xl font-black italic text-white tracking-tighter mb-4 uppercase leading-none">
      {t.payoff_1}
    </h2>
    <h2 class="text-4xl md:text-8xl font-black italic text-[#FF3366] tracking-tighter uppercase leading-none drop-shadow-[0_0_30px_rgba(255,51,102,0.6)] animate-pulse">
      {t.payoff_2}
    </h2>
    
    {/* Linea di chiusura stilizzata */}
    <div class="mt-12 w-24 h-1 bg-gradient-to-r from-transparent via-[#FF3366] to-transparent"></div>
  </div>

</section>
