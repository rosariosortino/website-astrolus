---
// src/components/ProductShowcase.astro
---
<section class="max-w-[1400px] mx-auto px-6 py-12">
  <div class="relative group cursor-pointer">
    
    {/* EFFETTO LUCE ESTERNA (GLOW) */}
    <div class="absolute -inset-1 bg-gradient-to-r from-[#00E5FF] to-[#FF3366] rounded-[2rem] blur-[20px] opacity-10 group-hover:opacity-40 transition duration-1000 group-hover:duration-300"></div>
    
    {/* CONTENITORE IMMAGINE */}
    <div class="relative bg-[#0a0a0a] rounded-[2rem] overflow-hidden border border-white/10 group-hover:border-[#00E5FF]/50 transition-all duration-500 shadow-2xl">
       <img 
        src="/player-full.png" 
        alt="Platinum Player Pro Interface" 
        class="w-full h-auto transition-transform duration-1000 group-hover:scale-[1.01]"
      />
      
      {/* RIFLESSO DINAMICO */}
      <div class="absolute inset-0 bg-gradient-to-tr from-[#00E5FF]/5 via-transparent to-[#FF3366]/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
    </div>

  </div>
</section>
