---
// src/components/ProductShowcase.astro
---
<section class="relative py-10 bg-[#050505] flex justify-center px-6">
  <div class="max-w-6xl w-full group">
    <div class="relative rounded-3xl overflow-hidden border border-white/10 transition-all duration-700 group-hover:border-[#00E5FF]/50 group-hover:shadow-[0_0_80px_rgba(0,229,255,0.3)]">
      
      {/* L'immagine del player */}
      <img 
        src="/player-full.png" 
        alt="Platinum Karaoke Pro Interface" 
        class="w-full h-auto transition-transform duration-1000 group-hover:scale-[1.02]"
      />

      {/* Sovrapposizione luminosa al tocco/hover */}
      <div class="absolute inset-0 bg-gradient-to-t from-[#00E5FF]/10 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"></div>
    </div>
  </div>
</section>
